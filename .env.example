DJANGO_SECRET_KEY=replace-with-a-strong-secret-key
ORACLE_CREDENTIAL_KEY=replace-with-a-valid-fernet-key
APP_VERSION=dev
BUILD_DATE=
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_LOG_LEVEL=INFO
AUTH_LOCAL_LOGIN_ENABLED=True
AUTH_AZUREAD_ENABLED=False
AUTH_AZUREAD_AUTO_SIGNUP=True
AUTH_AZUREAD_CLIENT_ID=
AUTH_AZUREAD_CLIENT_SECRET=
AUTH_AZUREAD_TENANT=organizations
AUTH_AZUREAD_LOGIN_URL=https://login.microsoftonline.com
AUTH_AZUREAD_GRAPH_URL=https://graph.microsoft.com
ORACLE_CLIENT_LIB_DIR=
ORACLE_CALL_TIMEOUT_MS=30000
QUERY_PREVIEW_MAX_ROWS=500
QUERY_ALLOWED_TABLES=
QUERY_ALLOWED_SCHEMAS=
MONITORING_CACHE_TTL_SECONDS=30
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_SECURE_REFERRER_POLICY=same-origin
DJANGO_SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
RUN_ORACLE_INTEGRATION_TESTS=0
ORACLE_TEST_HOST=
